@model ReportingIndexViewModel
@{
    ViewData["Title"] = "Department Reports";
}
<div class="container-fluid px-4 py-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0">Department Reports</h2>
        <a class="btn btn-outline-dark" asp-action="Index">Back to Operational Reports</a>
    </div>

    <form method="get" class="row g-3 mb-3">
        <div class="col-md-3"><label class="form-label">Department Id</label><input asp-for="Filters.DepartmentId" class="form-control" /></div>
        <div class="col-md-3"><label class="form-label">Export</label><select asp-for="Filters.Export" class="form-select" asp-items="Html.GetEnumSelectList<ERP.PL.ViewModels.Reporting.ReportExportFormat>()"></select></div>
        <div class="col-md-3 d-flex align-items-end"><button class="btn btn-primary w-100" type="submit">Apply</button></div>
        <div class="col-md-3 d-flex align-items-end"><a class="btn btn-outline-secondary w-100 export-link" asp-action="ExportDepartments" asp-route-DepartmentId="@Model.Filters.DepartmentId" asp-route-Export="@Model.Filters.Export">Export</a></div>
    </form>

    <div class="table-responsive">
        <table class="table table-striped table-hover table-sm">
            <thead class="table-light"><tr><th>Id</th><th>Code</th><th>Name</th><th>Employees</th><th>Projects</th><th>Open Tasks</th></tr></thead>
            <tbody>
                @foreach (var row in Model.DepartmentRows)
                {
                    <tr><td>@row.DepartmentId</td><td>@row.DepartmentCode</td><td>@row.DepartmentName</td><td>@row.EmployeesCount</td><td>@row.ProjectsCount</td><td>@row.OpenTasksCount</td></tr>
                }
            </tbody>
        </table>
    </div>
</div>

@section Scripts {
<script>
    (function () {
        var formatSelect = document.querySelector('[name="Filters.Export"]');
        if (!formatSelect) return;
        formatSelect.addEventListener('change', function () {
            var selectedFormat = formatSelect.options[formatSelect.selectedIndex].text;
            document.querySelectorAll('a.export-link').forEach(function (link) {
                var url = new URL(link.href, window.location.origin);
                url.searchParams.set('Export', selectedFormat);
                link.href = url.toString();
            });
        });
    })();
</script>
}