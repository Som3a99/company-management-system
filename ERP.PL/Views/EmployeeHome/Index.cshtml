@model EmployeeHomeDashboardViewModel
@{
    ViewData["Title"] = "My Workspace";
}

<div class="container-fluid px-4">
    <!-- Page Header -->
    <div class="dash-header animate-in">
        <div class="d-flex flex-wrap align-items-end justify-content-between gap-3">
            <div>
                <h1 class="dash-title">My Workspace</h1>
                <p class="dash-subtitle">Your tasks, projects &amp; assignments at a glance</p>
            </div>
            <div class="d-flex align-items-center gap-2" style="font-size: 0.8125rem; color: var(--text-muted);">
                <span class="badge bg-secondary" style="font-weight: 600; padding: 0.375rem 0.75rem;">Employee</span>
                @if (!string.IsNullOrWhiteSpace(Model.Position))
                {
                    <span style="color: var(--text-muted);">@Model.Position</span>
                }
            </div>
        </div>
    </div>

    <!-- Personal Summary Stats -->
    <div class="row g-3 mb-4 animate-in" style="animation-delay: 0.04s">
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(var(--accent-main-rgb), 0.1); color: var(--accent);">
                    <i class="fas fa-clipboard-list"></i>
                </div>
                <div>
                    <div class="stat-value">@Model.TotalAssignedTasks</div>
                    <div class="stat-label">Total Tasks</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(var(--info-rgb), 0.1); color: var(--info);">
                    <i class="fas fa-spinner"></i>
                </div>
                <div>
                    <div class="stat-value">@Model.InProgressTasks</div>
                    <div class="stat-label">In Progress</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card">
                <div class="stat-icon" style="background: rgba(var(--success-rgb), 0.1); color: var(--success);">
                    <i class="fas fa-check-circle"></i>
                </div>
                <div>
                    <div class="stat-value">@Model.CompletedTasks</div>
                    <div class="stat-label">Completed</div>
                </div>
            </div>
        </div>
        <div class="col-6 col-lg-3">
            <div class="stat-card" style="@(Model.OverdueCount > 0 ? "border-left: 3px solid var(--danger, #dc3545);" : "")">
                <div class="stat-icon" style="background: rgba(var(--danger-rgb, 220,53,69), 0.1); color: var(--danger, #dc3545);">
                    <i class="fas fa-exclamation-triangle"></i>
                </div>
                <div>
                    <div class="stat-value">@Model.OverdueCount</div>
                    <div class="stat-label">Overdue</div>
                </div>
            </div>
        </div>
    </div>

    <div class="row g-3 animate-in" style="animation-delay: 0.06s">
        <!-- Left column: Tasks -->
        <div class="col-lg-8">
            <!-- Overdue Tasks -->
            @if (Model.OverdueTasks.Any())
            {
                <div class="card mb-3" style="border-left: 3px solid var(--danger, #dc3545);">
                    <div class="card-body">
                        <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                            <i class="fas fa-exclamation-circle text-danger"></i>
                            Overdue Tasks
                            <span class="badge bg-danger rounded-pill">@Model.OverdueTasks.Count</span>
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Task</th>
                                        <th>Project</th>
                                        <th>Priority</th>
                                        <th>Due Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model.OverdueTasks)
                                    {
                                        <tr>
                                            <td>
                                                <a href="@Url.Action("Details", "TaskBoard", new { id = task.Id })" class="text-decoration-none fw-semibold">
                                                    @task.Title
                                                </a>
                                            </td>
                                            <td><small class="text-muted">@task.ProjectName</small></td>
                                            <td><span class="badge @task.PriorityBadgeClass">@task.Priority</span></td>
                                            <td>
                                                <small class="text-danger fw-semibold">
                                                    <i class="fas fa-clock me-1"></i>@task.DueDate?.ToString("MMM dd")
                                                </small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- Due Soon Tasks -->
            @if (Model.DueSoonTasks.Any())
            {
                <div class="card mb-3" style="border-left: 3px solid var(--warning, #ffc107);">
                    <div class="card-body">
                        <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                            <i class="fas fa-clock text-warning"></i>
                            Due Soon
                            <span class="badge bg-warning text-dark rounded-pill">@Model.DueSoonTasks.Count</span>
                        </h5>
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Task</th>
                                        <th>Project</th>
                                        <th>Priority</th>
                                        <th>Due Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model.DueSoonTasks)
                                    {
                                        <tr>
                                            <td>
                                                <a href="@Url.Action("Details", "TaskBoard", new { id = task.Id })" class="text-decoration-none fw-semibold">
                                                    @task.Title
                                                </a>
                                            </td>
                                            <td><small class="text-muted">@task.ProjectName</small></td>
                                            <td><span class="badge @task.PriorityBadgeClass">@task.Priority</span></td>
                                            <td>
                                                <small class="text-warning fw-semibold">
                                                    <i class="fas fa-calendar me-1"></i>@task.DueDate?.ToString("MMM dd")
                                                </small>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>
            }

            <!-- Active Tasks -->
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title d-flex align-items-center gap-2 mb-0">
                            <i class="fas fa-tasks" style="color: var(--accent);"></i>
                            My Active Tasks
                        </h5>
                        <a asp-controller="TaskBoard" asp-action="Index" class="btn btn-sm btn-outline-primary">
                            View All <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                    @if (Model.AssignedTasks.Any())
                    {
                        <div class="table-responsive">
                            <table class="table table-sm align-middle mb-0">
                                <thead>
                                    <tr>
                                        <th>Task</th>
                                        <th>Project</th>
                                        <th>Status</th>
                                        <th>Priority</th>
                                        <th>Due Date</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var task in Model.AssignedTasks)
                                    {
                                        <tr>
                                            <td>
                                                <a href="@Url.Action("Details", "TaskBoard", new { id = task.Id })" class="text-decoration-none fw-semibold">
                                                    @task.Title
                                                </a>
                                            </td>
                                            <td><small class="text-muted">@task.ProjectName</small></td>
                                            <td><span class="badge @task.StatusBadgeClass">@task.Status</span></td>
                                            <td><span class="badge @task.PriorityBadgeClass">@task.Priority</span></td>
                                            <td>
                                                @if (task.DueDate.HasValue)
                                                {
                                                    <small class="@(task.IsOverdue ? "text-danger fw-semibold" : task.IsDueSoon ? "text-warning" : "text-muted")">
                                                        @task.DueDate.Value.ToString("MMM dd")
                                                    </small>
                                                }
                                                else
                                                {
                                                    <small class="text-muted">—</small>
                                                }
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-4">
                            <i class="fas fa-check-circle fs-3 d-block mb-2" style="color: var(--success);"></i>
                            <p class="mb-0">No active tasks. You're all caught up!</p>
                        </div>
                    }
                </div>
            </div>
        </div>

        <!-- Right column: Info panels -->
        <div class="col-lg-4">
            <!-- My Department -->
            <div class="card mb-3">
                <div class="card-body">
                    <h5 class="card-title d-flex align-items-center gap-2 mb-3">
                        <i class="fas fa-sitemap" style="color: var(--accent);"></i>
                        My Department
                    </h5>
                    <div class="d-flex flex-column gap-2">
                        <div class="d-flex justify-content-between">
                            <small class="text-muted">Department</small>
                            <span class="fw-semibold">@Model.DepartmentName</span>
                        </div>
                        <div class="d-flex justify-content-between">
                            <small class="text-muted">Manager</small>
                            <span class="fw-semibold">@Model.ManagerName</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- My Projects -->
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title d-flex align-items-center gap-2 mb-0">
                            <i class="fas fa-folder-open" style="color: var(--accent);"></i>
                            My Projects
                        </h5>
                        <a asp-controller="Project" asp-action="Index" class="btn btn-sm btn-outline-primary">
                            All <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                    @if (Model.MyProjects.Any())
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (var project in Model.MyProjects)
                            {
                                <div class="d-flex justify-content-between align-items-center p-2 rounded" style="background: var(--bg-surface); border: 1px solid var(--border-color);">
                                    <div>
                                        <a href="@Url.Action("Details", "Project", new { id = project.Id })" class="text-decoration-none fw-semibold">
                                            @project.ProjectName
                                        </a>
                                        <div>
                                            <small class="text-muted">@project.TaskCount tasks</small>
                                        </div>
                                    </div>
                                    <span class="badge @project.StatusBadgeClass">@project.Status</span>
                                </div>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <i class="fas fa-folder fs-4 d-block mb-2"></i>
                            <small>No projects assigned</small>
                        </div>
                    }
                </div>
            </div>

            <!-- Recent Notifications -->
            <div class="card mb-3">
                <div class="card-body">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <h5 class="card-title d-flex align-items-center gap-2 mb-0">
                            <i class="fas fa-bell" style="color: var(--accent);"></i>
                            Notifications
                            @if (Model.UnreadNotificationCount > 0)
                            {
                                <span class="badge bg-danger rounded-pill">@Model.UnreadNotificationCount</span>
                            }
                        </h5>
                        <a href="/Notifications" class="btn btn-sm btn-outline-primary">
                            All <i class="fas fa-arrow-right ms-1"></i>
                        </a>
                    </div>
                    @if (Model.RecentNotifications.Any())
                    {
                        <div class="d-flex flex-column gap-2">
                            @foreach (var notif in Model.RecentNotifications)
                            {
                                <a href="@(notif.LinkUrl ?? "#")" class="text-decoration-none d-flex align-items-start gap-2 p-2 rounded @(!notif.IsRead ? "fw-semibold" : "opacity-75")"
                                   style="background: var(--bg-surface); border: 1px solid var(--border-color);">
                                    @if (notif.Severity == "critical")
                                    {
                                        <i class="fas fa-exclamation-triangle text-danger mt-1"></i>
                                    }
                                    else if (notif.Severity == "warning")
                                    {
                                        <i class="fas fa-clock text-warning mt-1"></i>
                                    }
                                    else
                                    {
                                        <i class="fas fa-bell text-primary mt-1"></i>
                                    }
                                    <div class="flex-grow-1 overflow-hidden">
                                        <div class="text-truncate" style="max-width: 200px; color: var(--text-heading);">@notif.Title</div>
                                        <small class="text-muted">@notif.TimeAgo</small>
                                    </div>
                                </a>
                            }
                        </div>
                    }
                    else
                    {
                        <div class="text-center text-muted py-3">
                            <i class="fas fa-bell-slash fs-4 d-block mb-2"></i>
                            <small>No recent notifications</small>
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .dash-header {
            padding: 1.5rem 0 1rem;
        }
        .dash-title {
            font-size: 1.75rem;
            font-weight: 700;
            color: var(--text-heading);
            margin-bottom: 0.25rem;
        }
        .dash-subtitle {
            font-size: 0.9375rem;
            color: var(--text-muted);
            margin: 0;
        }
        .stat-card {
            display: flex;
            align-items: center;
            gap: 0.875rem;
            padding: 1rem 1.25rem;
            border-radius: var(--radius-lg);
            background: var(--bg-card);
            border: 1px solid var(--border-color);
            transition: var(--transition-normal);
        }
        .stat-card:hover {
            border-color: var(--accent);
            box-shadow: var(--shadow-sm);
        }
        .stat-icon {
            width: 42px;
            height: 42px;
            border-radius: var(--radius-md);
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 1rem;
            flex-shrink: 0;
        }
        .stat-value {
            font-size: 1.375rem;
            font-weight: 700;
            color: var(--text-heading);
            line-height: 1.2;
        }
        .stat-label {
            font-size: 0.8125rem;
            color: var(--text-muted);
            font-weight: 500;
        }
        .card {
            border-radius: var(--radius-lg);
            border: 1px solid var(--border-color);
            background: var(--bg-card);
        }
        .card-title {
            font-size: 1rem;
            font-weight: 600;
            color: var(--text-heading);
        }
        .table > thead > tr > th {
            font-size: 0.75rem;
            text-transform: uppercase;
            letter-spacing: 0.05em;
            color: var(--text-muted);
            border-bottom-width: 1px;
        }
        .table > tbody > tr > td {
            font-size: 0.875rem;
            padding: 0.625rem 0.5rem;
        }
    </style>
}
