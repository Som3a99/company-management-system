<!DOCTYPE html>
<html lang="en" data-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CompanyFlow</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/ERP.PL.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/css/department-employees.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    <header class="navbar-container" id="mainNavbar">
        <nav class="navbar navbar-expand-lg navbar-custom" role="navigation" aria-label="Main navigation">
            <div class="container-fluid navbar-inner">
                @* ── Left Section: Brand ── *@
                <a class="navbar-brand" asp-area="" asp-controller="Home" asp-action="Index" aria-label="CompanyFlow home">
                    <div class="brand-icon" aria-hidden="true">
                        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <rect x="3" y="3" width="7" height="7" rx="2" fill="currentColor" opacity="0.9"/>
                            <rect x="3" y="14" width="7" height="7" rx="2" fill="currentColor" opacity="0.7"/>
                            <rect x="14" y="3" width="7" height="7" rx="2" fill="currentColor" opacity="0.7"/>
                            <rect x="14" y="14" width="7" height="7" rx="2" fill="currentColor" opacity="0.5"/>
                        </svg>
                    </div>
                    <span class="brand-text">CompanyFlow</span>
                </a>

                @* ── Mobile Toggle ── *@
                <div class="navbar-actions-mobile d-lg-none">
                    @if (User.Identity?.IsAuthenticated == true)
                    {
                        <button type="button" class="nav-icon-btn" data-theme-toggle aria-label="Toggle dark mode" title="Toggle dark mode">
                            <i class="fas fa-moon" data-theme-icon></i>
                        </button>
                    }
                    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav"
                            aria-controls="navbarNav" aria-expanded="false" aria-label="Toggle navigation">
                        <span class="toggler-bar"></span>
                        <span class="toggler-bar"></span>
                        <span class="toggler-bar"></span>
                    </button>
                </div>

                <div class="collapse navbar-collapse" id="navbarNav">
                    @* ── Center Section: Role-Based Navigation (partial views) ── *@
                    <ul class="navbar-nav navbar-center" role="menubar">
                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @if (User.IsInRole("CEO"))
                            {
                                @await Html.PartialAsync("_CeoNavbar")
                            }
                            else if (User.IsInRole("ITAdmin"))
                            {
                                @await Html.PartialAsync("_ITAdminNavbar")
                            }
                            else if (User.IsInRole("DepartmentManager") || User.IsInRole("ProjectManager"))
                            {
                                @await Html.PartialAsync("_ManagerNavbar")
                            }
                            else
                            {
                                @await Html.PartialAsync("_EmployeeNavbar")
                            }
                        }
                        else
                        {
                            <li class="nav-item" role="none">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Index" role="menuitem">
                                    <i class="fas fa-home nav-icon"></i>
                                    <span>Home</span>
                                </a>
                            </li>
                        }
                    </ul>

                    @* ── Right Section: Actions ── *@
                    <ul class="navbar-nav navbar-actions" role="menubar">
                        @* Theme Toggle (desktop only — mobile is in toggler area) *@
                        <li class="nav-item d-none d-lg-flex align-items-center" role="none">
                            <button type="button" class="nav-icon-btn" data-theme-toggle aria-label="Toggle dark mode" title="Toggle dark mode">
                                <i class="fas fa-moon" data-theme-icon></i>
                            </button>
                        </li>

                        @if (User.Identity?.IsAuthenticated == true)
                        {
                            @* ── Notification Bell ── *@
                            <li class="nav-item dropdown" role="none">
                                <a class="nav-icon-btn position-relative" href="#" id="notificationBell" role="menuitem"
                                   data-bs-toggle="dropdown" data-bs-auto-close="outside" aria-expanded="false"
                                   aria-label="Notifications">
                                    <i class="fas fa-bell"></i>
                                    <span id="notifBadge" class="notif-badge" style="display:none;">0</span>
                                </a>
                                <div class="dropdown-menu dropdown-menu-end notification-dropdown" aria-labelledby="notificationBell">
                                    <div class="notification-header">
                                        <h6 class="mb-0 fw-semibold">Notifications</h6>
                                        <button type="button" class="btn btn-sm btn-link text-decoration-none p-0" id="markAllReadBtn">
                                            Mark all read
                                        </button>
                                    </div>
                                    <div id="notifDropdownList" class="notification-body">
                                        <div class="text-center text-muted py-4">
                                            <i class="fas fa-bell-slash fs-4 mb-2 d-block opacity-50"></i>
                                            <small>No notifications</small>
                                        </div>
                                    </div>
                                    <div class="notification-footer">
                                        <a href="/Notifications" class="text-decoration-none small">View all notifications</a>
                                    </div>
                                </div>
                            </li>

                            @* ── Divider ── *@
                            <li class="nav-divider d-none d-lg-block" role="separator" aria-hidden="true"></li>

                            @* ── User Profile Dropdown ── *@
                            <li class="nav-item dropdown" role="none">
                                <a class="nav-link user-menu-toggle" href="#" id="userMenu" role="menuitem"
                                   data-bs-toggle="dropdown" aria-expanded="false" aria-label="User menu">
                                    <span class="user-avatar">
                                        <i class="fas fa-user"></i>
                                    </span>
                                    <span class="user-name d-none d-xl-inline">@User.Identity.Name</span>
                                    <i class="fas fa-chevron-down user-caret d-none d-lg-inline"></i>
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end user-dropdown" aria-labelledby="userMenu">
                                    <li class="user-dropdown-header">
                                        <span class="user-dropdown-name">@User.Identity.Name</span>
                                        @if (User.IsInRole("CEO"))
                                        {
                                            <span class="user-role-badge role-ceo">CEO</span>
                                        }
                                        else if (User.IsInRole("ITAdmin"))
                                        {
                                            <span class="user-role-badge role-admin">IT Admin</span>
                                        }
                                        else if (User.IsInRole("DepartmentManager"))
                                        {
                                            <span class="user-role-badge role-manager">Manager</span>
                                        }
                                        else if (User.IsInRole("ProjectManager"))
                                        {
                                            <span class="user-role-badge role-pm">PM</span>
                                        }
                                        else
                                        {
                                            <span class="user-role-badge role-employee">Employee</span>
                                        }
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="Profile">
                                            <i class="fas fa-id-badge me-2 dropdown-item-icon"></i>My Profile
                                        </a>
                                    </li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Account" asp-action="ChangePassword">
                                            <i class="fas fa-key me-2 dropdown-item-icon"></i>Change Password
                                        </a>
                                    </li>
                                    @if (User.IsInRole("CEO") || User.IsInRole("ITAdmin"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="Account" asp-action="ResetPasswordByAdmin">
                                                <i class="fas fa-user-lock me-2 dropdown-item-icon"></i>Reset User Password
                                            </a>
                                        </li>
                                    }
                                    @if (User.IsInRole("DepartmentManager"))
                                    {
                                        <li>
                                            <a class="dropdown-item" asp-controller="DepartmentManagerHr" asp-action="Index">
                                                <i class="fas fa-cogs me-2 dropdown-item-icon"></i>Manage Team
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <a class="dropdown-item" asp-area="" asp-controller="Home" asp-action="Privacy">
                                            <i class="fas fa-shield-alt me-2 dropdown-item-icon"></i>Privacy Policy
                                        </a>
                                    </li>
                                    <li><hr class="dropdown-divider"></li>
                                    <li>
                                        <form asp-controller="Account" asp-action="Logout" method="post" class="dropdown-item p-0">
                                            <button type="submit" class="btn btn-link dropdown-item text-danger">
                                                <i class="fas fa-sign-out-alt me-2"></i>Logout
                                            </button>
                                        </form>
                                    </li>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item" role="none">
                                <a class="nav-link" asp-area="" asp-controller="Home" asp-action="Privacy" role="menuitem">Privacy</a>
                            </li>
                            <li class="nav-item ms-1" role="none">
                                <a asp-controller="Account" asp-action="Login" class="btn-login">
                                    <span>Login</span>
                                    <i class="fas fa-arrow-right ms-1"></i>
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>

    <main class="main-content">
        <!-- Success/Error Message Display -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="container-fluid px-4 mt-3">
                <div class="alert alert-success alert-dismissible fade show d-flex align-items-center gap-3" role="alert">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        <polyline points="22 4 12 14.01 9 11.01" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                    </svg>
                    <div>@TempData["SuccessMessage"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        @if (TempData["ErrorMessage"] != null)
        {
            <div class="container-fluid px-4 mt-3">
                <div class="alert alert-danger alert-dismissible fade show d-flex align-items-center gap-3" role="alert">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2" />
                        <line x1="15" y1="9" x2="9" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                        <line x1="9" y1="9" x2="15" y2="15" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
                    </svg>
                    <div>@TempData["ErrorMessage"]</div>
                    <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                </div>
            </div>
        }

        @RenderBody()
    </main>

    <footer class="footer-custom">
        <div class="container-fluid px-4">
            <div class="footer-content">
                <span class="footer-text">&copy; 2026 CompanyFlow. All rights reserved.</span>
                <span class="footer-version">v1.0.0</span>
            </div>
        </div>
    </footer>

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>

    @if (User.Identity?.IsAuthenticated == true)
    {
        <script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
        <script>
            // ── Notification Bell System (SignalR + polling fallback) ──
            (function () {
                const bellBadge = document.getElementById('notifBadge');
                const dropdownList = document.getElementById('notifDropdownList');
                const markAllBtn = document.getElementById('markAllReadBtn');

                if (!bellBadge || !dropdownList) return;

                let signalRConnected = false;

                function severityIcon(sev) {
                    switch (sev) {
                        case 'critical': return '<i class="fas fa-exclamation-triangle text-danger me-2 mt-1 fs-6"></i>';
                        case 'warning': return '<i class="fas fa-clock text-warning me-2 mt-1 fs-6"></i>';
                        default: return '<i class="fas fa-bell text-primary me-2 mt-1 fs-6"></i>';
                    }
                }

                function severityBg(sev) {
                    switch (sev) {
                        case 'critical': return 'bg-danger-subtle';
                        case 'warning': return 'bg-warning-subtle';
                        default: return '';
                    }
                }

                function renderNotifications(items) {
                    if (!items || items.length === 0) {
                        dropdownList.innerHTML = '<div class="text-center text-muted py-4"><i class="fas fa-bell-slash fs-4 mb-2 d-block"></i><small>No notifications</small></div>';
                        return;
                    }

                    dropdownList.innerHTML = items.map(n => {
                        const sev = typeof n.severity === 'number'
                            ? ['info', 'warning', 'critical'][n.severity] || 'info'
                            : (n.severity || 'info');
                        const readClass = n.isRead ? 'opacity-75' : 'fw-semibold';
                        const bgClass = n.isRead ? '' : severityBg(sev);
                        const newBadge = n.isRead ? '' : '<span class="badge rounded-pill bg-primary ms-1" style="font-size:0.55rem">New</span>';

                        return `<a href="${n.linkUrl || '#'}" class="dropdown-item d-flex align-items-start py-2 px-3 ${bgClass} ${readClass}" data-notif-id="${n.id}" onclick="markNotifRead(${n.id}, event)">
                            ${severityIcon(sev)}
                            <div class="flex-grow-1 overflow-hidden">
                                <div class="text-truncate" style="max-width:280px">${n.title}</div>
                                <small class="text-muted text-truncate d-block" style="max-width:280px">${n.message}</small>
                                <small class="text-muted">${n.timeAgo || ''}</small>
                            </div>
                            ${newBadge}
                        </a>`;
                    }).join('');
                }

                function updateBadge(count) {
                    if (count > 0) {
                        bellBadge.textContent = count > 99 ? '99+' : count;
                        bellBadge.style.display = '';
                    } else {
                        bellBadge.style.display = 'none';
                    }
                }

                function refreshBadge() {
                    fetch('/Notifications/UnreadCount')
                        .then(r => r.json())
                        .then(data => updateBadge(data.count))
                        .catch(() => { });
                }

                function loadRecent() {
                    fetch('/Notifications/Recent')
                        .then(r => r.json())
                        .then(items => renderNotifications(items))
                        .catch(() => { });
                }

                // Mark single notification read
                window.markNotifRead = function (id, event) {
                    fetch('/Notifications/MarkRead?id=' + id, { method: 'POST' })
                        .then(() => {
                            refreshBadge();
                            const item = dropdownList.querySelector(`[data-notif-id="${id}"]`);
                            if (item) {
                                item.classList.remove('fw-semibold', 'bg-danger-subtle', 'bg-warning-subtle');
                                item.classList.add('opacity-75');
                                const badge = item.querySelector('.badge');
                                if (badge) badge.remove();
                            }
                        })
                        .catch(() => { });
                };

                if (markAllBtn) {
                    markAllBtn.addEventListener('click', function () {
                        fetch('/Notifications/MarkAllRead', { method: 'POST' })
                            .then(() => {
                                refreshBadge();
                                loadRecent();
                            })
                            .catch(() => { });
                    });
                }

                // Load on bell click
                const bellEl = document.getElementById('notificationBell');
                if (bellEl) {
                    bellEl.addEventListener('show.bs.dropdown', loadRecent);
                }

                // ── Toast for critical alerts ──
                function showCriticalToast(n) {
                    const sev = typeof n.severity === 'number'
                        ? ['info', 'warning', 'critical'][n.severity] || 'info'
                        : (n.severity || 'info');
                    if (sev !== 'critical') return;

                    const key = 'toast_seen_' + n.id;
                    if (sessionStorage.getItem(key)) return;
                    sessionStorage.setItem(key, '1');

                    let container = document.getElementById('notifToastContainer');
                    if (!container) {
                        container = document.createElement('div');
                        container.id = 'notifToastContainer';
                        container.className = 'toast-container position-fixed top-0 end-0 p-3';
                        container.style.zIndex = '1090';
                        document.body.appendChild(container);
                    }
                    const toastId = 'toast_' + n.id;
                    const html = `<div id="${toastId}" class="toast border-danger" role="alert" aria-live="assertive" aria-atomic="true" data-bs-autohide="true" data-bs-delay="8000">
                        <div class="toast-header">
                            <i class="fas fa-exclamation-triangle me-2"></i>
                            <strong class="me-auto">${n.title}</strong>
                            <small class="text-muted">${n.timeAgo || 'just now'}</small>
                            <button type="button" class="btn-close ms-2" data-bs-dismiss="toast" aria-label="Close"></button>
                        </div>
                        <div class="toast-body">${n.message}</div>
                    </div>`;
                    container.insertAdjacentHTML('beforeend', html);
                    const toastEl = document.getElementById(toastId);
                    if (toastEl && bootstrap.Toast) {
                        new bootstrap.Toast(toastEl).show();
                    }
                }

                function checkCriticalAlerts() {
                    fetch('/Notifications/Recent')
                        .then(r => r.json())
                        .then(items => {
                            (items || []).filter(n => !n.isRead).forEach(n => showCriticalToast(n));
                        })
                        .catch(() => { });
                }

                // ── SignalR Connection (graceful fallback to polling) ──
                let pollingTimer = null;
                let criticalTimer = null;

                function startPolling() {
                    if (pollingTimer) return;
                    pollingTimer = setInterval(refreshBadge, 60000);
                    criticalTimer = setInterval(checkCriticalAlerts, 60000);
                }

                function stopPolling() {
                    if (pollingTimer) { clearInterval(pollingTimer); pollingTimer = null; }
                    if (criticalTimer) { clearInterval(criticalTimer); criticalTimer = null; }
                }

                if (typeof signalR !== 'undefined') {
                    const connection = new signalR.HubConnectionBuilder()
                        .withUrl('/hubs/notifications')
                        .withAutomaticReconnect([0, 2000, 5000, 10000, 30000])
                        .configureLogging(signalR.LogLevel.Warning)
                        .build();

                    connection.on('ReceiveNotification', function (notification) {
                        // Show toast for critical
                        showCriticalToast(notification);
                        // If dropdown is open, refresh it
                        const bellMenu = document.querySelector('#notificationBell + .dropdown-menu');
                        if (bellMenu && bellMenu.classList.contains('show')) {
                            loadRecent();
                        }
                    });

                    connection.on('UpdateUnreadCount', function (count) {
                        updateBadge(count);
                    });

                    connection.onreconnecting(function () {
                        signalRConnected = false;
                        startPolling(); // Fall back to polling during reconnect
                    });

                    connection.onreconnected(function () {
                        signalRConnected = true;
                        stopPolling();
                        refreshBadge(); // Sync after reconnect
                    });

                    connection.onclose(function () {
                        signalRConnected = false;
                        startPolling();
                    });

                    connection.start()
                        .then(function () {
                            signalRConnected = true;
                            // No polling needed when SignalR is connected
                        })
                        .catch(function () {
                            signalRConnected = false;
                            startPolling(); // Graceful fallback
                        });
                } else {
                    // SignalR script not available — use polling
                    startPolling();
                }

                // Initial loads (always needed regardless of transport)
                refreshBadge();
                checkCriticalAlerts();
            })();
        </script>
    }

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>