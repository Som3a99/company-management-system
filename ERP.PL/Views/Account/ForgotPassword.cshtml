@model ForgotPasswordViewModel

@{
    ViewData["Title"] = "Forgot Password";
    Layout = "~/Views/Shared/_PublicLayout.cshtml";
}

<div class="auth-page-wrapper">
    <div class="container">
        <div class="row justify-content-center account-readable">
            <div class="col-md-6 col-lg-5">
                <div class="text-center mb-4 animate-in">
                    <div class="auth-logo mx-auto mb-3">
                        <i class="fas fa-key" style="font-size: 1.25rem;"></i>
                    </div>
                    <h2 class="auth-heading">Reset your password</h2>
                    <p class="auth-subheading">Choose how you'd like to reset your password</p>
                </div>

                <!-- Step 1: Email Access Question -->
                <div id="stepEmailAccess" class="card auth-card animate-in" style="animation-delay: 0.08s">
                    <div class="card-body p-4">
                        <div class="text-center mb-4">
                            <i class="fas fa-envelope-open-text" style="font-size: 2rem; color: var(--accent-main); margin-bottom: 0.5rem;"></i>
                            <h5 class="mb-1" style="color: var(--text-heading); font-weight: 600;">Do you have access to your email?</h5>
                            <p class="mb-0" style="font-size: 0.875rem; color: var(--text-muted);">
                                This helps us determine the fastest way to reset your password.
                            </p>
                        </div>

                        <div class="d-grid gap-3">
                            <button type="button" class="btn btn-outline-primary btn-lg d-flex align-items-center gap-3 p-3" onclick="showResetForm(true)" style="border-radius: var(--radius-lg); text-align: left;">
                                <div style="width: 44px; height: 44px; border-radius: var(--radius-md); background: rgba(var(--accent-main-rgb), 0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <i class="fas fa-check-circle" style="color: var(--accent-main);"></i>
                                </div>
                                <div>
                                    <strong style="display: block; font-size: 0.9375rem;">Yes, I can access my email</strong>
                                    <small style="color: var(--text-muted); font-weight: 400;">We'll send you a reset link — quickest option</small>
                                </div>
                            </button>

                            <button type="button" class="btn btn-outline-secondary btn-lg d-flex align-items-center gap-3 p-3" onclick="showResetForm(false)" style="border-radius: var(--radius-lg); text-align: left;">
                                <div style="width: 44px; height: 44px; border-radius: var(--radius-md); background: rgba(var(--neutral-rgb), 0.1); display: flex; align-items: center; justify-content: center; flex-shrink: 0;">
                                    <i class="fas fa-times-circle" style="color: var(--neutral);"></i>
                                </div>
                                <div>
                                    <strong style="display: block; font-size: 0.9375rem;">No, I can't access my email</strong>
                                    <small style="color: var(--text-muted); font-weight: 400;">IT Admin will review your request manually</small>
                                </div>
                            </button>
                        </div>

                        <div class="text-center mt-3">
                            <a asp-action="Login" class="text-decoration-none" style="font-size: 0.875rem; color: var(--text-muted);">
                                <i class="fas fa-arrow-left me-1"></i> Back to Login
                            </a>
                        </div>
                    </div>
                </div>

                <!-- Step 2: Email Form (shown after choice) -->
                <div id="stepEmailForm" class="card auth-card animate-in" style="display: none; animation-delay: 0.08s">
                    <div class="card-body p-4">
                        <div id="emailResetInfo" class="alert alert-soft mb-4" style="font-size: 0.875rem; display: none;">
                            <div class="d-flex gap-2">
                                <i class="fas fa-info-circle mt-1" style="color: var(--info-emphasis);"></i>
                                <div>
                                    <strong>Email Reset:</strong>
                                    <p class="mb-0 mt-1">Enter your email and we'll send you a secure link to reset your password.</p>
                                </div>
                            </div>
                        </div>

                        <div id="itTicketInfo" class="alert alert-soft mb-4" style="font-size: 0.875rem; display: none;">
                            <div class="d-flex gap-2">
                                <i class="fas fa-info-circle mt-1" style="color: var(--info-emphasis);"></i>
                                <div>
                                    <strong>IT Admin Reset Process:</strong>
                                    <ol class="mb-0 mt-2 ps-3">
                                        <li>Submit your company email address</li>
                                        <li>A ticket will be created for IT Admin review</li>
                                        <li>Try logging in after 30 minutes</li>
                                        <li>If still locked, visit the IT desk with your employee ID</li>
                                    </ol>
                                </div>
                            </div>
                        </div>

                        <form asp-action="ForgotPassword" method="post">
                            <div asp-validation-summary="All" class="text-danger mb-3" style="font-size: 0.875rem;"></div>
                            <input type="hidden" asp-for="HasEmailAccess" id="hasEmailAccessInput" />

                            <div class="mb-4">
                                <label asp-for="Email" class="form-label"></label>
                                <div class="input-group">
                                    <span class="input-group-text">
                                        <i class="fas fa-envelope"></i>
                                    </span>
                                    <input asp-for="Email"
                                           class="form-control"
                                           placeholder="your.email@company.com"
                                           autocomplete="email" />
                                </div>
                                <span asp-validation-for="Email" class="text-danger" style="font-size: 0.8125rem;"></span>
                            </div>

                            <div class="d-grid gap-2">
                                <button type="submit" class="btn btn-primary btn-primary-lg" id="submitBtn">
                                    <i class="fas fa-paper-plane"></i> <span id="submitBtnText">Submit</span>
                                </button>
                                <button type="button" class="btn btn-outline-secondary" onclick="showStep1()">
                                    <i class="fas fa-arrow-left"></i> Back
                                </button>
                            </div>
                        </form>
                    </div>
                </div>

                <p class="text-center mt-3 animate-in" style="font-size: 0.8125rem; color: var(--text-muted); animation-delay: 0.16s">
                    <i class="fas fa-lock me-1"></i> Your information is handled securely
                </p>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .auth-page-wrapper {
            display: flex;
            align-items: center;
            justify-content: center;
            min-height: calc(100vh - 200px);
            padding: 2rem 0;
        }
        .auth-logo {
            width: 52px;
            height: 52px;
            background: linear-gradient(135deg, var(--accent-main), var(--accent-light));
            border-radius: var(--radius-lg);
            display: flex;
            align-items: center;
            justify-content: center;
            color: white;
            box-shadow: 0 4px 16px rgba(var(--accent-main-rgb), 0.3);
        }
        .auth-heading {
            font-size: 1.5rem;
            font-weight: 700;
            color: var(--text-heading);
            margin-bottom: 0.25rem;
        }
        .auth-subheading {
            font-size: 0.9375rem;
            color: var(--text-muted);
            margin: 0;
        }
        .auth-card .form-control {
            background: var(--bg-secondary);
        }
        .auth-card .form-control:focus {
            background: var(--bg-main);
        }
    </style>
}

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
    <script>
        function showResetForm(hasAccess) {
            document.getElementById('stepEmailAccess').style.display = 'none';
            document.getElementById('stepEmailForm').style.display = 'block';
            document.getElementById('hasEmailAccessInput').value = hasAccess ? 'true' : 'false';

            if (hasAccess) {
                document.getElementById('emailResetInfo').style.display = 'block';
                document.getElementById('itTicketInfo').style.display = 'none';
                document.getElementById('submitBtnText').textContent = 'Send Reset Link';
            } else {
                document.getElementById('emailResetInfo').style.display = 'none';
                document.getElementById('itTicketInfo').style.display = 'block';
                document.getElementById('submitBtnText').textContent = 'Submit Request';
            }
        }

        function showStep1() {
            document.getElementById('stepEmailAccess').style.display = 'block';
            document.getElementById('stepEmailForm').style.display = 'none';
        }
    </script>
}